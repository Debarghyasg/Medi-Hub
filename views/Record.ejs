<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/png" href="Medi-Hub2.png">
    <title>My Records — MediCare</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --primary: #4f46e5;
            --primary-hover: #4338ca;
            --bg-body: #f8fafc;
            --text-main: #1e293b;
            --text-muted: #64748b;
            --white: #ffffff;
            --shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
        }

        body {
            margin: 0;
            padding: 0;
            background-color: var(--bg-body);
            font-family: 'DM Sans', sans-serif;
            color: var(--text-main);
        }

        .records-section {
            max-width: 1200px;
            margin: 0 auto;
            padding: 40px 20px;
        }

        .records-header {
            margin-bottom: 40px;
            border-bottom: 2px solid #e2e8f0;
            padding-bottom: 20px;
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
        }

        .records-header h2 {
            font-family: 'DM Serif Display', serif;
            font-size: 2.5rem;
            margin: 0;
            color: #0f172a;
        }

        .count-badge {
            background: var(--primary);
            color: white;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.9rem;
            font-weight: 500;
        }

        /* Grid Logic */
        .records-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 24px;
        }

        /* Card Styling */
        .record-card {
            background: var(--white);
            border-radius: 16px;
            padding: 24px;
            box-shadow: var(--shadow);
            border: 1px solid #e2e8f0;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
            position: relative;
            display: flex;
            flex-direction: column;
        }

        .record-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1);
        }

        /* Delete Button */
        .btn-delete {
            position: absolute;
            top: 15px;
            right: 15px;
            background: #fee2e2;
            color: #ef4444;
            border: none;
            width: 32px;
            height: 32px;
            border-radius: 50%;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            transition: background 0.2s;
        }

        .btn-delete:hover {
            background: #fecaca;
        }

        /* Status & Date */
        .card-meta {
            display: flex;
            justify-content: space-between;
            margin-bottom: 20px;
            font-size: 0.85rem;
        }

        .status-pill {
            padding: 4px 10px;
            border-radius: 12px;
            font-weight: 600;
            text-transform: capitalize;
        }

        .status-pill.done { background: #dcfce7; color: #166534; }
        .status-pill.processing { background: #fef9c3; color: #854d0e; }
        .status-pill.failed { background: #fee2e2; color: #991b1b; }

        /* Card Details */
        .detail-group {
            margin-bottom: 15px;
        }

        .detail-label {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: var(--text-muted);
            margin-bottom: 4px;
            display: block;
        }

        .detail-value {
            font-size: 1.1rem;
            font-weight: 500;
            margin: 0;
        }

        /* Action Footer */
        .card-footer {
            margin-top: auto;
            padding-top: 20px;
            border-top: 1px solid #f1f5f9;
        }

        .btn-view {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: var(--primary);
            text-decoration: none;
            font-weight: 600;
            font-size: 0.95rem;
        }

        .btn-view:hover {
            text-decoration: underline;
        }

        @media (max-width: 640px) {
            .records-header { flex-direction: column; align-items: flex-start; gap: 10px; }
            .records-header h2 { font-size: 2rem; }
        }
    </style>
</head>
<body>

<section class="records-section">
    <div class="records-header">
        <h2>My Medical Records</h2>
        <span class="count-badge"><%= prescriptions.length %> Prescriptions</span>
    </div>

    <div class="records-grid">
        <% if (prescriptions.length === 0) { %>
            <div style="grid-column: 1/-1; text-align: center; padding: 50px; color: var(--text-muted);">
                <p>No records found. Start by uploading a prescription!</p>
                <a href="/home" style="color: var(--primary); font-weight: bold;">Go to Dashboard</a>
            </div>
        <% } %>

        <% prescriptions.forEach(record => { %>
            <div class="record-card">
                <form action="/delete-record/<%= record.id %>" method="POST" onsubmit="return confirm('Delete this record?')">
                    <button type="submit" class="btn-delete" title="Delete Record">✕</button>
                </form>

                <div class="card-meta">
                    <span class="status-pill <%= record.status %>"><%= record.status %></span>
                    <span style="color: var(--text-muted)">
                        <%= new Date(record.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                    </span>
                </div>

                <div class="detail-group">
                    <span class="detail-label">Physician / Clinic</span>
                    <p class="detail-value"><%= record.doctor_name || 'Unidentified Doctor' %></p>
                </div>

                <div class="detail-group">
                    <span class="detail-label">Follow-up Date</span>
                    <p class="detail-value" style="color: var(--primary);">
                        <%= record.next_visit || 'None Scheduled' %>
                    </p>
                </div>

                <div class="card-footer">
                    <a href="/<%= record.file_path %>" target="_blank" class="btn-view">
                        View Prescription Image ↗
                    </a>
                </div>
            </div>
        <% }) %>
    </div>
</section>

</body>
</html>