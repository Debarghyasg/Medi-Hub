<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<link rel="icon" type="image/png" href="Medi-Hub2.png">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Medi Hub — Sign In</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --cream: #f5f0e8;
    --warm-white: #faf8f4;
    --gold: #c9a84c;
    --gold-light: #e4c87a;
    --dark: #1a1612;
    --mid: #4a3f35;
    --glass: rgba(250, 248, 244, 0.08);
    --glass-border: rgba(201, 168, 76, 0.25);
  }

  body {
    font-family: 'Times New Roman', sans-serif;
    font-weight: 300;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    /* background: var(--dark); */
  }

  /* Animated background */
  .bg {
    position: fixed;
    inset: 0;
    background-image: url('Homebg.jpg');
    opacity: 0.9 !important;
    background-size: cover;
    background-position: center;
    filter: brightness(0.45) saturate(0.8);
    transform: scale(1.05);
    animation: slowdrift 10s ease-in-out infinite alternate;
    z-index: 0;
  }

  @keyframes slowdrift {
    from { transform: scale(1.05) translateX(0); }
    to { transform: scale(1.1) translateX(-2%); }
  }

  /* Overlay gradient */
  .overlay {
    position: fixed;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(26, 22, 18, 0.6) 0%,
      rgba(74, 63, 53, 0.3) 50%,
      rgba(26, 22, 18, 0.7) 100%
    );
    z-index: 1;
  }

  /* Noise texture overlay */
  .noise {
    position: fixed;
    inset: 0;
    opacity: 0.035;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    background-size: 200px;
    z-index: 2;
    pointer-events: none;
  }

  /* Card container */
  .container {
    position: relative;
    z-index: 10;
    width: 420px;
    animation: fadein 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    opacity: 0;
    transform: translateY(24px);
  }

  @keyframes fadein {
    to { opacity: 1; transform: translateY(0); }
  }

  .card {
    background: rgba(26, 22, 18, 0.72);
    backdrop-filter: blur(28px) saturate(1.4);
    -webkit-backdrop-filter: blur(28px) saturate(1.4);
    border: 1px solid var(--glass-border);
    border-radius: 2px;
    padding: 52px 48px 48px;
    box-shadow: 0 32px 80px rgba(0,0,0,0.5), inset 0 1px 0 rgba(201, 168, 76, 0.15);
  }

  /* Logo / Brand */
  .brand {
    text-align: center;
    margin-bottom: 36px;
  }

  .brand-mark {
    display: inline-block;
    width: 44px;
    height: 44px;
    
    
    position: relative;
    margin-bottom: 16px;
  }

  .brand-mark::before {
    content: '';
    position: absolute;
    inset: 7px;
    /* border: 1px solid rgba(201, 168, 76, 0.4); */
    
  }

  .brand-mark::after {
    content: '';
    position: absolute;
    width: 6px; height: 6px;
    /* background: var(--gold); */
    
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
  }

  .brand-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 28px;
    font-weight: 300;
    letter-spacing: 0.3em;
    color: var(--cream);
    text-transform: uppercase;
  }

  /* Tab switcher */
  .tabs {
    display: flex;
    gap: 0;
    margin-bottom: 36px;
    border-bottom: 1px solid rgba(201, 168, 76, 0.2);
  }

  .tab {
    flex: 1;
    background: none;
    border: none;
    padding: 0 0 14px;
    font-family: 'Jost', sans-serif;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(245, 240, 232, 0.35);
    cursor: pointer;
    position: relative;
    transition: color 0.3s;
  }

  .tab.active {
    color: var(--gold);
  }

  .tab::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    height: 1.5px;
    background: var(--gold);
    transform: scaleX(0);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .tab.active::after {
    transform: scaleX(1);
  }

  /* Forms */
  .form { display: block; }

  .field {
    margin-bottom: 20px;
    position: relative;
  }

  label {
    display: block;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(201, 168, 76, 0.7);
    margin-bottom: 8px;
  }

  input {
    width: 100%;
    background: rgba(245, 240, 232, 0.05);
    border: 1px solid rgba(201, 168, 76, 0.2);
    border-radius: 1px;
    padding: 13px 16px;
    font-family: 'Jost', sans-serif;
    font-size: 14px;
    font-weight: 300;
    color: var(--cream);
    outline: none;
    transition: border-color 0.3s, background 0.3s, box-shadow 0.3s;
  }

  input::placeholder {
    color: rgba(245, 240, 232, 0.2);
  }

  input:focus {
    border-color: var(--gold);
    background: rgba(201, 168, 76, 0.06);
    box-shadow: 0 0 0 3px rgba(201, 168, 76, 0.08);
  }

  /* Submit button */
  .btn {
    width: 100%;
    margin-top: 8px;
    padding: 15px;
    background: linear-gradient(135deg, var(--gold) 0%, var(--gold-light) 50%, var(--gold) 100%);
    background-size: 200% 100%;
    border: none;
    border-radius: 1px;
    font-family: 'Jost', sans-serif;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--dark);
    cursor: pointer;
    transition: background-position 0.4s, box-shadow 0.3s, transform 0.2s;
  }

  .btn:hover {
    background-position: 100% 0;
    box-shadow: 0 8px 32px rgba(201, 168, 76, 0.3);
    transform: translateY(-1px);
  }

  .btn:active {
    transform: translateY(0);
  }

  /* Divider */
  .divider {
    display: flex;
    align-items: center;
    gap: 16px;
    margin: 24px 0;
  }

  .divider::before, .divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: rgba(201, 168, 76, 0.15);
  }

  .divider span {
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(245, 240, 232, 0.25);
  }

  /* Social buttons */
  .social-row {
    display: flex;
    gap: 12px;
  }

   .social-btn {
    flex: 1;
    padding: 11px;
    background: rgba(245, 240, 232, 0.04);
    border: 1px solid rgba(201, 168, 76, 0.15);
    border-radius: 1px;
    font-family: 'Jost', sans-serif;
    font-size: 11px;
    letter-spacing: 0.1em;
    cursor: pointer;
    transition: all 0.3s;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 7px;
    
    color: rgba(255, 255, 255, 0.89);
     font-family: Times New Roman, serif;
     font-size: 11px;
  } 

  

  .social-btn:hover {
    background: rgba(245, 240, 232, 0.08);
    color: var(--cream);
    border-color: rgba(201, 168, 76, 0.35);
  }

  .social-btn svg {
    width: 14px;
    height: 14px;
    fill: currentColor;
  }

  /* Footer note */
  .note {
    text-align: center;
    margin-top: 28px;
    font-size: 11px;
    color: rgba(245, 240, 232, 0.25);
    letter-spacing: 0.05em;
  }

  .note a {
    color: var(--gold);
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .note a:hover { opacity: 0.7; }

  /* Row for inline fields */
  .field-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  /* Checkbox */
  .check-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 20px;
  }

  .check-row input[type="checkbox"] {
    width: 14px;
    height: 14px;
    accent-color: var(--gold);
    padding: 0;
  }

  .check-row label {
    margin: 0;
    font-size: 11px;
    letter-spacing: 0.05em;
    text-transform: none;
    color: rgba(245, 240, 232, 0.35);
    cursor: pointer;
  }
 

  .forgot {
    float: right;
    font-size: 10px;
    letter-spacing: 0.1em;
    color: rgba(201, 168, 76, 0.6);
    text-decoration: none;
    margin-bottom: 8px;
    display: block;
    text-align: right;
    transition: color 0.2s;
  }
  .signpage{
    font-size: 11px;
    color: rgba(255, 255, 255, 0.89);
     font-family: Times New Roman, serif;
     text-decoration: none !important;
     transition: color 0.2s;
  }

  .forgot:hover { color: var(--gold); }
</style>
</head>
<body>

<div class="bg"></div>
<div class="overlay"></div>
<div class="noise"></div>

<div class="container">
  <div class="card">

    <div class="brand">
      <div class="brand-mark">
        <img src="Medi-Hub2.png" alt="Logo" style="width:50px; height:50px;">
      </div>
      <div class="brand-name">Medi Hub</div>
    </div>

    <!-- LOGIN FORM -->
    <div class="form active" id="login">
        <form action="/" method="POST">
      <div class="field">
        <label for="l-email">Email Address</label>
        <input type="email" id="l-email" name="email" placeholder="abc@example.com">
      </div>
      <div class="field">
        <label for="l-pass">Password</label>
        <input type="password" id="l-pass" name="password" placeholder="••••••••">
        <a href="#" class="forgot">Forgot password?</a>
      </div>
      <div class="check-row">
        <input type="checkbox" id="remember">
        <label for="remember">Keep me signed in</label>
      </div>
      <button class="btn">Sign In</button>
      </form>

      <div class="divider"><span>or continue with</span></div>

      <div class="social-row">
        <!-- <button class="social-btn">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
          Google
        </button> -->
         <button class="social-btn" href="/signup">
          <a href="/signup"><h3 class="signpage">Don't have an account?</h3></a>
          
        </button>
      </div>
    </div>



  </div>
</div>


</body>
</html>